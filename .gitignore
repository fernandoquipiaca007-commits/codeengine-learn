# =========================================================
# CodeEngine Learn - .gitignore
# =========================================================

# ---------- Dependencies ----------
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ---------- Build outputs ----------
dist/
build/
out/
.next/
.vercel/
.turbo/
coverage/
**/dist/
**/build/

# ---------- Environment ----------
.env
.env.*
!.env.example
!.env.stripe.example
!.env.*.example

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ---------- Editor / OS ----------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo

# ---------- TypeScript ----------
*.tsbuildinfo
.tsbuildinfo

# ---------- Cache ----------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache/

# ---------- Testing ----------
coverage/
.nyc_output/

# ---------- Supabase ----------
# (supabase/ lives inside backend repo)
backend/supabase/.temp/
backend/supabase/.branches/

# ---------- Sub-repositories (each has its own git) ----------
# admin/ and backend/ are SEPARATE git repositories. Do not commit them here.
admin/
backend/

# ---------- Sensitive / local-only ----------
*.pem
*.key
*.crt
secrets.json

# ---------- Misc ----------
*.local
.history/
scratch/
